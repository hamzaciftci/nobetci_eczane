# Frontend
VITE_API_BASE_URL=
# NOT: Admin token'ı buraya EKLEME. VITE_ prefixli değişkenler JS bundle'a gömülür.
# Admin paneli token'ı sayfa içi giriş formu üzerinden (sessionStorage) girilir.
# Optional local dev proxy target
VITE_API_PROXY_TARGET=

# Vercel / Neon backend
DATABASE_URL=
# optional alias
NEON_DATABASE_URL=

# Admin endpoints token — ZORUNLU (production'da ayarlanmazsa tüm admin endpoint'ler 503 döner)
# Güçlü rastgele token önerisi: openssl rand -hex 32
ADMIN_API_TOKEN=

# Cron ingestion token (Vercel cron Authorization: Bearer <CRON_SECRET>)
# Güçlü rastgele token önerisi: openssl rand -hex 32
CRON_SECRET=
